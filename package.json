{
  "name": "playwright-testmo-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Playwright + TypeScript boilerplate with POM, Page Factory, fixtures, and Testmo integration.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "testmo:submit": "testmo automation:run:submit --instance \"$TESTMO_URL\" --project-id \"$TESTMO_PROJECT_ID\" --name \"Playwright Automated Run\" --source \"github-actions\" --results \"test-results/junit-report.xml\"",
    "test:ci": "npm run test && npm run testmo:submit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testmo/testmo-cli": "^1.4.9",
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  }
}
